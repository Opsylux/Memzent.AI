# Memzent local / staging environment template
# Copy to .env and fill in real values. Never commit .env to git.

# --- Core ---
ENVIRONMENT=development
# Production: set a strong random secret (gateway refuses default in production)
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated origins. Production requires this (no wildcard).
# Development default: * (all origins) when unset
# CORS_ALLOWED_ORIGINS=http://localhost:3002,http://localhost:5173

# Dev-only: expose GET /generate-token
# ENABLE_DEV_TOKEN=true

# --- Gateway ---
PORT=:8080
VALKEY_URL=valkey:6379
ROUTER_URL=router:50051
POSTGRES_URL=postgresql://user:password@host:5432/postgres?sslmode=require
MCP_SERVER_URL=http://memzent-mcp-server:50052/mcp

# --- Supabase Auth (dashboard JWT verification) ---
JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional dev JWK seed (not used in production unless explicitly set)
# SUPABASE_STATIC_JWK=

# --- LLM Providers (optional — Ollama is default) ---
OLLAMA_ENABLED=true
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# --- Billing (optional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRODUCT_ID=
# STRIPE_BIZ_PRODUCT_ID=
# STRIPE_PRO_PRICE_ID=
# STRIPE_BIZ_PRICE_ID=
# STRIPE_SUCCESS_URL=http://localhost:3002/billing?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=http://localhost:3002/billing?status=cancel

# --- Dashboard (docker-compose) ---
# Browser-facing URL (host machine)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
# Server-side URL inside docker network (dashboard container → gateway)
GATEWAY_INTERNAL_URL=http://memzent-gateway:8080
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# --- Website (docker-compose) ---
VITE_APP_URL=http://localhost:3002
VITE_GATEWAY_URL=http://localhost:8080
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Qdrant DR (optional) ---
# QDRANT_S3_ACCESS_KEY=
# QDRANT_S3_SECRET_KEY=
SNAPSHOT_INTERVAL_HOURS=24

# --- Load test script (scripts/test_flow.go) ---
# MEMZENT_ORG_ID=your-org-uuid
# MEMZENT_API_KEY=memzent_your_api_key
# GATEWAY_URL=http://localhost:8080
