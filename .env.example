# Memzent Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database (Required) ───────────────────────────────────────────────────────
# Option A: Supabase (recommended — free tier works)
#   Create a project at https://supabase.com → Settings → Database → Connection string
# Option B: Any PostgreSQL 15+ instance
POSTGRES_URL=postgresql://postgres:password@localhost:5432/memzent

# ─── Supabase Auth (Required for Dashboard) ───────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
JWKS_URL=https://your-project.supabase.co/auth/v1/jwks

# ─── Gateway Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-min-32-chars

# ─── LLM Providers (at least one required) ────────────────────────────────────
# Ollama (local, free) — install from https://ollama.ai
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=...

# ─── Stripe (Optional — for billing/payments) ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Infrastructure (defaults work for docker-compose) ─────────────────────────
# VALKEY_URL=valkey:6379
# ROUTER_URL=router:50051
# ENVIRONMENT=development

# ─── Caching & Invalidation (Optional) ────────────────────────────────────────
# TTL applied to all Valkey/durable cache entries.
# LLM_CACHE_TTL=1h
# Minimum tool-match similarity score (0..1).
# TOOL_RELEVANCE_THRESHOLD=0.7
# Cache entries are automatically partitioned per caller preference (role +
# system prompt) and per org cache version, so preference or policy changes
# invalidate stale answers without additional configuration.

