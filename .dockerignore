# Exclude entire dashboard from build context (uses pre-built image, not built via Dockerfile)
# Also prevents Docker failure on Windows due to parentheses in (app) directory name
services/dashboard

# Exclude website node_modules (has its own Dockerfile)
website/node_modules

# Ignore heavy ML model caches
**/.fastembed_cache
**/.cache

# Ignore local target and package lockups
**/target
**/node_modules
**/.next

# Ignore data folders
data/qdrant